---
interface Props {
  title: string
  year: number
  description: string
  thumbnail: string
  video: string
}

const { title, year, description, thumbnail, video } = Astro.props
---

<article class="branding-card" data-video={`/videos/branding/${video}`}>
  <div class="card-media">
    <img
      class="card-thumb"
      src={`/images/projects/${thumbnail}`}
      alt={title}
      loading="lazy"
    />
    <video
      class="card-video"
      muted
      loop
      playsinline
      preload="none"
      aria-hidden="true"
    >
      <source src={`/videos/branding/${video}`} type="video/mp4" />
    </video>
  </div>

  <div class="card-info">
    <h3 class="card-title">{title}</h3>
    <div class="card-meta">
      <span>{description}</span>
      <span class="card-year">{year}</span>
    </div>
  </div>
</article>

<style>
  .branding-card {
    position: relative;
    overflow: hidden;
  }

  .card-media {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-text-dark-muted);
  }

  .card-thumb,
  .card-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s;
  }

  .card-video {
    opacity: 0;
  }

  .branding-card:hover .card-video {
    opacity: 1;
  }

  .card-info {
    padding: 1.25rem 0 0;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-dark);
    margin-bottom: 0.5rem;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-dark-muted);
  }

  .card-year {
    flex-shrink: 0;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.branding-card').forEach((card) => {
    const video = card.querySelector('video')
    if (!video) return

    card.addEventListener('mouseenter', () => {
      video.play().catch(() => undefined)
    })

    card.addEventListener('mouseleave', () => {
      video.pause()
      video.currentTime = 0
    })
  })
</script>
