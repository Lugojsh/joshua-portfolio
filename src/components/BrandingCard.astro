---
interface Props {
  title: string
  year: number
  description: string
  thumbnail: string
  video: string
}

const { title, year, description, video } = Astro.props
---

<article class="branding-card">
  <button class="card-btn" aria-expanded="false">
    <div class="card-media">
      <video
        class="card-video"
        muted
        loop
        playsinline
        preload="none"
      >
        <source src={`/videos/branding/${video}`} type="video/mp4" />
      </video>

      <div class="card-overlay">
        <span class="card-title">{title}</span>
        <span class="card-year">{year}</span>
      </div>
    </div>
  </button>

  <div class="card-details" aria-hidden="true">
    <p class="card-desc">{description}</p>
  </div>
</article>

<style>
  .branding-card {
    position: relative;
    flex: 1;
    min-width: 0;
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: flex 0.5s ease, opacity 0.4s ease;
  }


  .card-btn {
    display: block;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
  }

  .card-media {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #111;
    transition: aspect-ratio 0.5s ease;
  }

  .branding-card.active .card-media {
    aspect-ratio: 4/5;
  }

  .card-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .branding-card.active .card-video,
  .card-btn:hover .card-video {
    transform: scale(1.03);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 55%);
  }

  .card-title {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 0.3rem;
  }

  .card-year {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-wide);
    color: rgba(255, 255, 255, 0.55);
  }

  /* Expandable details — inside the card */
  .card-details {
    overflow: hidden;
    height: 0;
    background: #1a1a1a;
  }

  .card-desc {
    font-family: var(--font-body);
    font-size: clamp(0.85rem, 1.1vw, 0.95rem);
    font-weight: var(--weight-light);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    padding: 1.1rem 1.25rem 1.25rem;
    margin: 0;
  }
</style>
