---
import contentData from '../data/content.json'

const { bio, disciplines, stats, aboutPhoto } = contentData

const col1 = disciplines.slice(0, 3)
const col2 = disciplines.slice(3)
---

<section id="about">
  <div class="about-inner">
    <div class="about-left">
      <span class="section-label">ABOUT</span>
      <p class="about-bio">{bio}</p>
      <img
        src={`/images/${aboutPhoto}`}
        alt="Joshua Lugo"
        class="about-photo"
        onload="this.style.display='block'"
        onerror="this.style.display='none'"
      />
      <a href="/cv/JoshuaLugo_CV.pdf" download class="cv-btn">↓ Descargar CV</a>
    </div>

    <div class="about-right">
      <div class="stats">
        <div class="stat">
          <div class="stat-value">
            <span class="stat-number" data-count={stats.years}>{stats.years}</span><span class="stat-suffix">+</span>
          </div>
          <span class="stat-label">años de experiencia</span>
        </div>
        <div class="stat">
          <div class="stat-value">
            <span class="stat-number" data-count={stats.disciplines}>{stats.disciplines}</span>
          </div>
          <span class="stat-label">disciplinas</span>
        </div>
      </div>

      <div class="disciplines-grid">
        <ul class="disciplines">
          {col1.map((d) => (
            <li class="discipline-item"><span>{d}</span></li>
          ))}
        </ul>
        <ul class="disciplines">
          {col2.map((d) => (
            <li class="discipline-item"><span>{d}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  #about {
    background: var(--color-bg);
    padding: 4rem 2rem;
    border-top: 1px solid var(--color-border);
  }

  .about-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .section-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .about-bio {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: var(--weight-light);
    line-height: 1.7;
    color: var(--color-text);
    max-width: 46ch;
  }

  .about-photo {
    display: none;
    width: 100%;
    max-width: 46ch;
    margin-top: 2rem;
    object-fit: cover;
  }

  .cv-btn {
    display: inline-block;
    margin-top: 2.5rem;
    font-family: var(--font-body);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 0.25rem;
    transition: opacity 0.2s;
  }

  .cv-btn:hover {
    opacity: 0.5;
  }

  .stats {
    display: flex;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-value {
    display: flex;
    align-items: baseline;
    gap: 0.1em;
    line-height: 1;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
  }

  .stat-suffix {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2.5rem);
    font-weight: var(--weight-black);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  .disciplines-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 2rem;
  }

  .disciplines {
    list-style: none;
  }

  .discipline-item {
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 1.2vw, 1rem);
    font-weight: var(--weight-regular);
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .discipline-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    #about {
      padding: 3rem 1rem;
    }

    .stats {
      margin-bottom: 2rem;
    }

    .section-label {
      margin-bottom: 1rem;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  gsap.from('#about .about-left > *', {
    scrollTrigger: { trigger: '#about', start: 'top 75%' },
    y: 40,
    opacity: 0,
    stagger: 0.15,
    duration: 0.8,
    ease: 'power2.out',
  })

  document.querySelectorAll<HTMLElement>('.stat-number').forEach((el) => {
    const target = parseInt(el.dataset['count'] ?? '0', 10)
    gsap.fromTo(el,
      { innerText: 0 },
      {
        scrollTrigger: { trigger: '#about', start: 'top 70%' },
        innerText: target,
        duration: 1.5,
        ease: 'power2.out',
        snap: { innerText: 1 },
        onUpdate() {
          el.innerText = String(Math.round(parseFloat(el.innerText)))
        },
      }
    )
  })

  gsap.from('.discipline-item', {
    scrollTrigger: { trigger: '.disciplines-grid', start: 'top 80%' },
    x: 30,
    opacity: 0,
    stagger: 0.07,
    duration: 0.6,
    ease: 'power2.out',
  })
</script>
