---
import CursorTrail from './CursorTrail.astro'
import Grain from './ui/Grain.astro'

const word1 = 'JOSHUA'.split('')
const word2 = 'LUGO'.split('')
---

<section id="hero" class="section-dark">
  <Grain />
  <CursorTrail />

  <!-- Rolling shapes -->
  <div class="rolling-shapes" aria-hidden="true">
    <div class="rs rs-1"></div>
    <div class="rs rs-2"></div>
    <div class="rs rs-3"></div>
    <div class="rs rs-4"></div>
    <div class="rs rs-5"></div>
    <div class="rs rs-6"></div>
    <div class="rs rs-7"></div>
    <div class="rs rs-8"></div>
  </div>

  <div class="hero-content">
    <h1 class="hero-name" aria-label="Joshua Lugo">
      <span class="hero-word">
        { word1.map((c) => <span class="char">{c}</span>) }
      </span>
      <span class="hero-word">
        { word2.map((c) => <span class="char">{c}</span>) }
      </span>
    </h1>
  </div>

  <div class="hero-bottom">
    <p class="hero-meta-left">DISEÑO, IMAGEN &amp; MOVIMIENTO.</p>
    <p class="hero-meta-right">
      CDMX — <span id="hero-clock"></span>
    </p>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100svh;
    background: var(--color-bg-dark);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 6rem 2rem 3rem;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: 0.9;
    color: var(--color-text-dark);
    display: flex;
    align-items: flex-end;
    gap: 0.22em;
  }

  .hero-word {
    display: inline-flex;
  }

  .char {
    display: inline-block;
    will-change: transform, filter, opacity;
  }

  .hero-bottom {
    position: absolute;
    bottom: 2.5rem;
    left: 2rem;
    right: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 2;
  }

  .hero-meta-left,
  .hero-meta-right {
    font-family: var(--font-body);
    font-size: var(--text-meta);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-dark-muted);
    text-transform: uppercase;
  }

  /* ── Rolling shapes ── */
  .rolling-shapes {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  .rs {
    position: absolute;
  }

  @keyframes roll-r {
    from { transform: translateX(-220px) rotate(0deg); }
    to   { transform: translateX(calc(100vw + 220px)) rotate(720deg); }
  }

  @keyframes roll-l {
    from { transform: translateX(calc(100vw + 220px)) rotate(0deg); }
    to   { transform: translateX(-220px) rotate(-720deg); }
  }

  .rs-1 {
    width: 78px; height: 78px;
    border-radius: 50%;
    background: #E03A2F;
    bottom: 9%;
    animation: roll-l 7s ease-in-out infinite;
  }
  .rs-2 {
    width: 108px; height: 64px;
    border-radius: 32px;
    background: #4A90D9;
    bottom: 4%;
    animation: roll-r 9s ease-in-out infinite;
    animation-delay: -3.2s;
  }
  .rs-3 {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: #F5C418;
    bottom: 18%;
    animation: roll-r 5.5s ease-in-out infinite;
    animation-delay: -1.8s;
  }
  .rs-4 {
    width: 92px; height: 56px;
    border-radius: 28px;
    background: #4CAF50;
    bottom: 7%;
    animation: roll-l 8.5s ease-in-out infinite;
    animation-delay: -5.5s;
  }
  .rs-5 {
    width: 86px; height: 86px;
    border-radius: 50%;
    background: #4A90D9;
    bottom: 24%;
    animation: roll-l 10s ease-in-out infinite;
    animation-delay: -2.5s;
  }
  .rs-6 {
    width: 64px; height: 40px;
    border-radius: 20px;
    background: #E03A2F;
    bottom: 13%;
    animation: roll-r 7s ease-in-out infinite;
    animation-delay: -6.5s;
  }
  .rs-7 {
    width: 88px; height: 54px;
    border-radius: 27px;
    background: #F5C418;
    bottom: 5%;
    animation: roll-l 9.5s ease-in-out infinite;
    animation-delay: -4s;
  }
  .rs-8 {
    width: 46px; height: 46px;
    border-radius: 50%;
    background: #4CAF50;
    bottom: 30%;
    animation: roll-r 6.5s ease-in-out infinite;
    animation-delay: -8s;
  }

  @media (max-width: 640px) {
    #hero {
      padding: 5rem 1.25rem 2rem;
    }

    .hero-name {
      flex-direction: column;
      align-items: center;
      gap: 0.05em;
      font-size: clamp(3.5rem, 20vw, 6rem);
    }

    .hero-bottom {
      left: 1rem;
      right: 1rem;
    }

    .hero-meta-left {
      display: none;
    }

    .rs-5, .rs-8 {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap'

  // Chars enter left→right with rotation + blur — like shapes becoming letters
  const tl = gsap.timeline({ delay: 0.2 })
  tl.from('.hero-name .char', {
    x: -50,
    rotation: -22,
    filter: 'blur(14px)',
    opacity: 0,
    transformOrigin: 'left center',
    stagger: 0.05,
    duration: 0.75,
    ease: 'power3.out',
  })
  .from('.hero-bottom', { opacity: 0, y: 8, duration: 0.5, ease: 'power2.out' }, '-=0.4')

  // Real-time clock
  const clockEl = document.getElementById('hero-clock')
  function updateClock() {
    if (!clockEl) return
    const now = new Date()
    clockEl.textContent = now.toLocaleTimeString('es-MX', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      timeZone: 'America/Mexico_City',
    })
  }
  updateClock()
  setInterval(updateClock, 1000)

  // Cursor trail — only active inside #hero
  const hero = document.getElementById('hero')!
  const trailImgs = document.querySelectorAll<HTMLImageElement>('.trail-img')

  if (trailImgs.length > 0) {
    let current = 0
    let lastX = 0
    let lastY = 0
    let isInHero = false

    const validImgs = Array.from(trailImgs).filter(
      (img) => img.complete && img.naturalWidth > 0,
    )

    hero.addEventListener('mouseenter', () => { isInHero = true })
    hero.addEventListener('mouseleave', () => {
      isInHero = false
      validImgs.forEach((img) => { gsap.to(img, { opacity: 0, duration: 0.3 }) })
    })

    let lastTime = 0
    hero.addEventListener('mousemove', (e) => {
      if (!isInHero) return
      const now = Date.now()
      if (now - lastTime < 80) return
      lastTime = now

      const dx = e.clientX - lastX
      const dy = e.clientY - lastY
      if (Math.sqrt(dx * dx + dy * dy) < 20) return

      lastX = e.clientX
      lastY = e.clientY
      if (validImgs.length === 0) return

      const img = validImgs[current % validImgs.length]
      current++

      const rotation = (Math.random() - 0.5) * 16
      gsap.set(img, { x: e.clientX, y: e.clientY })
      gsap.fromTo(
        img,
        { opacity: 0, scale: 0.8, rotation: rotation - 4 },
        {
          opacity: 1, scale: 1, rotation, duration: 0.4, ease: 'power2.out',
          onComplete() {
            gsap.to(img, { opacity: 0, duration: 0.4, delay: 0.6, ease: 'power2.in' })
          },
        },
      )
    })
  }
</script>
