---
import CursorTrail from './CursorTrail.astro'
import Grain from './ui/Grain.astro'

---

<section id="hero">
  <Grain />
  <CursorTrail />

  <div class="hero-content">
    <h1 class="hero-name" aria-label="Joshua Lugo">
      <span class="word-wrap"><span class="word">JOSHUA</span></span>
      <span class="word-wrap"><span class="word">LUGO</span></span>
    </h1>
  </div>

  <div class="hero-bottom">
    <p class="hero-meta-left">DISEÑO, IMAGEN &amp; MOVIMIENTO.</p>
    <p class="hero-meta-right">
      CDMX — <span id="hero-clock"></span>
    </p>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100svh;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 6rem 2rem 3rem;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: 0.9;
    color: var(--color-text);
    display: flex;
    align-items: flex-end;
    gap: 0.22em;
  }

  .word-wrap {
    display: block;
    overflow: hidden;
    line-height: 0.92;
  }

  .word {
    display: block;
    will-change: transform;
  }

  .hero-bottom {
    position: absolute;
    bottom: 2.5rem;
    left: 2rem;
    right: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 2;
  }

  .hero-meta-left,
  .hero-meta-right {
    font-family: var(--font-body);
    font-size: var(--text-meta);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    #hero {
      padding: 5rem 1.25rem 2rem;
    }

    .hero-name {
      flex-direction: column;
      align-items: center;
      gap: 0.05em;
      font-size: clamp(3.5rem, 20vw, 6rem);
    }

    .hero-bottom {
      left: 1rem;
      right: 1rem;
    }

    .hero-meta-left {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap'

  const tl = gsap.timeline({ delay: 0.15 })
  tl.from('.hero-name .word', {
    yPercent: 115,
    duration: 1.1,
    stagger: 0.13,
    ease: 'power4.out',
  })
    .from('.hero-bottom', { opacity: 0, y: 8, duration: 0.5, ease: 'power2.out' }, '-=0.5')

  // Real-time clock
  const clockEl = document.getElementById('hero-clock')
  function updateClock() {
    if (!clockEl) return
    const now = new Date()
    clockEl.textContent = now.toLocaleTimeString('es-MX', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      timeZone: 'America/Mexico_City',
    })
  }
  updateClock()
  setInterval(updateClock, 1000)

  // Cursor trail — only active inside #hero
  const hero = document.getElementById('hero')!
  const trailImgs = document.querySelectorAll<HTMLImageElement>('.trail-img')

  if (trailImgs.length > 0) {
    let current = 0
    let lastX = 0
    let lastY = 0
    let isInHero = false

    const validImgs = Array.from(trailImgs).filter(
      (img) => img.complete && img.naturalWidth > 0,
    )

    hero.addEventListener('mouseenter', () => { isInHero = true })

    hero.addEventListener('mouseleave', () => {
      isInHero = false
      validImgs.forEach((img) => { gsap.to(img, { opacity: 0, duration: 0.3 }) })
    })

    let lastTime = 0
    hero.addEventListener('mousemove', (e) => {
      if (!isInHero) return
      const now = Date.now()
      if (now - lastTime < 80) return
      lastTime = now

      const dx = e.clientX - lastX
      const dy = e.clientY - lastY
      if (Math.sqrt(dx * dx + dy * dy) < 20) return

      lastX = e.clientX
      lastY = e.clientY
      if (validImgs.length === 0) return

      const img = validImgs[current % validImgs.length]
      current++

      const rotation = (Math.random() - 0.5) * 16
      gsap.set(img, { x: e.clientX, y: e.clientY })
      gsap.fromTo(
        img,
        { opacity: 0, scale: 0.8, rotation: rotation - 4 },
        {
          opacity: 1, scale: 1, rotation, duration: 0.4, ease: 'power2.out',
          onComplete() {
            gsap.to(img, { opacity: 0, duration: 0.4, delay: 0.6, ease: 'power2.in' })
          },
        },
      )
    })
  }
</script>
