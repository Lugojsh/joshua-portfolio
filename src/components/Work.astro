---
import ProjectItem from './ProjectItem.astro'
import projectsData from '../data/projects.json'

interface Project {
  id: string
  title: string
  category: string
  year: number
  thumbnail: string
  client?: string
  description?: string
}

const projects = projectsData as Project[]
---

<section id="work">
  <div class="work-inner">
    <div class="work-header">
      <h2 class="section-title">TRABAJO</h2>
    </div>

    <ul class="work-list">
      {
        projects.map((project, i) => (
          <ProjectItem
            index={i + 1}
            title={project.title}
            category={project.category}
            year={project.year}
            thumbnail={project.thumbnail}
          />
        ))
      }
    </ul>
  </div>

  <!-- Hover preview image -->
  <div id="work-preview" aria-hidden="true">
    <img id="work-preview-img" src="" alt="" />
  </div>
</section>

<style>
  #work {
    background: var(--color-bg);
    padding: 8rem 2rem;
    border-top: 1px solid var(--color-border);
  }

  .work-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .work-header {
    margin-bottom: 4rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: 0.9;
    color: var(--color-text);
  }

  .work-list {
    padding: 0;
    margin: 0;
  }

  /* Hover preview */
  #work-preview {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 20;
    opacity: 0;
    will-change: transform, opacity;
  }

  #work-preview-img {
    width: 280px;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 2px;
    display: block;
  }

  @media (max-width: 768px) {
    #work {
      padding: 4rem 1rem;
    }

    #work-preview {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  // Stagger entrance
  gsap.from('.project-item', {
    scrollTrigger: { trigger: '.work-list', start: 'top 80%' },
    y: 50,
    opacity: 0,
    stagger: 0.07,
    duration: 0.7,
    ease: 'power2.out',
  })

  // Hover preview
  const preview = document.getElementById('work-preview')!
  const previewImg = document.getElementById('work-preview-img') as HTMLImageElement
  const items = document.querySelectorAll<HTMLElement>('.project-item')

  let mouseX = 0
  let mouseY = 0

  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX
    mouseY = e.clientY
    gsap.set(preview, {
      x: mouseX + 24,
      y: mouseY - 80,
    })
  })

  items.forEach((item) => {
    const src = item.dataset['thumbnail'] ?? ''

    item.addEventListener('mouseenter', () => {
      if (!src) return
      previewImg.src = src
      gsap.fromTo(
        preview,
        { scale: 0.92, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.35, ease: 'power2.out' },
      )
    })

    item.addEventListener('mouseleave', () => {
      gsap.to(preview, { opacity: 0, duration: 0.25, ease: 'power2.in' })
    })
  })
</script>
