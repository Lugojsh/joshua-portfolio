---
import projectsData from '../data/projects.json'

interface Project {
  id: string
  title: string
  category: string
  year: number
  thumbnail: string
  client?: string
  description?: string
}

const projects = projectsData as Project[]
---

<section id="work">
  <div class="work-inner">
    <div class="work-header">
      <h2 class="section-title">TRABAJOS DESTACADOS</h2>
    </div>

    <div class="carousel-wrap">
      <div class="carousel-viewport">
        {
          projects.map((project, i) => (
            <button
              class="carousel-item"
              data-index={i}
              aria-label={project.title}
              data-description={project.description ?? ''}
              data-client={project.client ?? ''}
            >
              <span class="item-arrow">→</span>
              <span class="item-title">{project.title}</span>
              <span class="item-meta">{project.category} · {project.year}</span>
            </button>
          ))
        }
      </div>

      <div class="project-info">
        <p class="project-desc"></p>
        <span class="project-client"></span>
      </div>
    </div>
  </div>
</section>

<style>
  #work {
    background: var(--color-bg);
    padding: 4rem 2rem;
    border-top: 1px solid var(--color-border);
  }

  .work-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .work-header {
    margin-bottom: 3rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: 0.9;
    color: var(--color-text);
  }

  .carousel-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .carousel-viewport {
    position: relative;
    height: 380px;
    overflow: hidden;
    perspective: 1000px;
    perspective-origin: center center;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 22%,
      black 78%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 22%,
      black 78%,
      transparent 100%
    );
  }

  .carousel-item {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    text-align: left;
    transform-origin: left center;
    will-change: transform, filter, opacity;
    opacity: 0;
  }

  .item-arrow {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.8vw, 1.4rem);
    color: var(--color-text);
    opacity: 0;
    transform: translateX(-12px);
    transition: none;
    flex-shrink: 0;
  }

  .item-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.5vw, 3rem);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--color-text);
  }

  .item-meta {
    font-family: var(--font-body);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* Right panel — project info */
  .project-info {
    opacity: 0;
  }

  .project-desc {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    font-weight: var(--weight-light);
    line-height: 1.7;
    color: var(--color-text);
    max-width: 48ch;
    margin-bottom: 1rem;
  }

  .project-client {
    font-family: var(--font-body);
    font-size: var(--text-meta);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .carousel-wrap {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .carousel-viewport {
      height: 300px;
    }

    .project-info {
      padding-left: 0;
    }

    #work {
      padding: 4rem 1rem;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  const items = Array.from(document.querySelectorAll<HTMLElement>('.carousel-item'))
  const descEl = document.querySelector<HTMLElement>('.project-desc')!
  const clientEl = document.querySelector<HTMLElement>('.project-client')!
  const infoPanel = document.querySelector<HTMLElement>('.project-info')!

  const ITEM_GAP = 88
  let activeIndex = 0

  function setActive(idx: number, animate = true) {
    const n = items.length
    activeIndex = ((idx % n) + n) % n

    items.forEach((item, i) => {
      let offset = i - activeIndex
      if (offset > n / 2) offset -= n
      if (offset < -n / 2) offset += n
      const absOffset = Math.abs(offset)
      const arrow = item.querySelector<HTMLElement>('.item-arrow')!
      const h = item.offsetHeight || 36

      const props = {
        y: offset * ITEM_GAP - h / 2,
        scale: Math.max(0.52, 1 - absOffset * 0.18),
        filter: `blur(${Math.min(7, absOffset * 2.2)}px)`,
        opacity: Math.max(0.08, 1 - absOffset * 0.28),
        rotateX: `${offset * -12}deg`,
      }

      if (animate) {
        gsap.to(item, { ...props, duration: 0.75, ease: 'power3.out', overwrite: 'auto' })
        gsap.to(arrow, {
          opacity: offset === 0 ? 1 : 0,
          x: offset === 0 ? 0 : -14,
          duration: 0.5,
          ease: 'power2.out',
          overwrite: 'auto',
        })
      } else {
        gsap.set(item, props)
        gsap.set(arrow, { opacity: offset === 0 ? 1 : 0, x: offset === 0 ? 0 : -14 })
      }
    })

    const activeItem = items[activeIndex]
    const descText = activeItem.dataset['description'] ?? ''
    const clientText = activeItem.dataset['client'] ?? ''

    if (animate) {
      gsap.to(infoPanel, {
        opacity: 0, y: 10, duration: 0.2, overwrite: 'auto',
        onComplete() {
          descEl.textContent = descText
          clientEl.textContent = clientText
          gsap.to(infoPanel, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' })
        },
      })
    } else {
      descEl.textContent = descText
      clientEl.textContent = clientText
    }
  }

  let carouselReady = false

  ScrollTrigger.create({
    trigger: '#work',
    start: 'top 75%',
    once: true,
    onEnter() {
      if (carouselReady) return
      carouselReady = true

      // Position all items instantly — offsetHeight is reliable at this point
      setActive(0, false)

      // Fade each item in from 0 to its correct opacity
      items.forEach((item) => {
        gsap.from(item, { opacity: 0, duration: 0.5, ease: 'power2.out' })
      })

      // Auto-advance
      let timer = setInterval(() => setActive(activeIndex + 1), 3000)

      items.forEach((item, i) => {
        item.addEventListener('click', () => {
          clearInterval(timer)
          setActive(i)
          timer = setInterval(() => setActive(activeIndex + 1), 3000)
        })
      })

      const viewport = document.querySelector<HTMLElement>('.carousel-viewport')!
      viewport.addEventListener('wheel', (e) => {
        e.preventDefault()
        clearInterval(timer)
        if (e.deltaY > 0) setActive(activeIndex + 1)
        else setActive(activeIndex - 1)
        timer = setInterval(() => setActive(activeIndex + 1), 3000)
      }, { passive: false })
    },
  })
</script>
