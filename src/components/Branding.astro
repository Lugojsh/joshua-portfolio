---
import BrandingCard from './BrandingCard.astro'
import brandingData from '../data/branding.json'

interface BrandingProject {
  id: string
  title: string
  year: number
  description: string
  thumbnail: string
  video: string
}

const brandings = brandingData as BrandingProject[]
---

<section id="branding" class="section-dark">
  <div class="branding-inner">
    <div class="branding-header">
      <h2 class="section-title-dark">BRANDING</h2>
    </div>

    <div class="branding-grid">
      {
        brandings.map((b) => (
          <BrandingCard
            title={b.title}
            year={b.year}
            description={b.description}
            thumbnail={b.thumbnail}
            video={b.video}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  #branding {
    padding: 8rem 2rem;
  }

  .branding-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .branding-header {
    margin-bottom: 4rem;
  }

  .section-title-dark {
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: 0.9;
    color: var(--color-text-dark);
  }

  .branding-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  @media (max-width: 1024px) {
    .branding-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    #branding {
      padding: 4rem 1rem;
    }

    .branding-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  gsap.from('.branding-card', {
    scrollTrigger: { trigger: '.branding-grid', start: 'top 75%' },
    y: 60,
    opacity: 0,
    stagger: 0.1,
    duration: 0.8,
    ease: 'power2.out',
  })
</script>
