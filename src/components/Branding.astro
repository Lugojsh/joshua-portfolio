---
import BrandingCard from './BrandingCard.astro'
import brandingData from '../data/branding.json'

interface BrandingProject {
  id: string
  title: string
  year: number
  description: string
  thumbnail: string
  video: string
}

const brandings = brandingData as BrandingProject[]
---

<section id="branding" class="section-dark">
  <div class="branding-inner">
    <div class="branding-header">
      <h2 class="section-title-dark">BRANDING</h2>
    </div>

    <div class="branding-grid">
      {
        brandings.map((b) => (
          <BrandingCard
            title={b.title}
            year={b.year}
            description={b.description}
            thumbnail={b.thumbnail}
            video={b.video}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  #branding {
    padding: 4rem 2rem;
  }

  .branding-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .branding-header {
    margin-bottom: 4rem;
  }

  .section-title-dark {
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: 0.9;
    color: var(--color-text-dark);
  }

  .branding-grid {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  @media (max-width: 640px) {
    #branding {
      padding: 4rem 1rem;
    }

    .branding-grid {
      flex-direction: column;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  gsap.from('.branding-card', {
    immediateRender: false,
    scrollTrigger: { trigger: '.branding-grid', start: 'top 75%', once: true },
    y: 60,
    opacity: 0,
    stagger: 0.1,
    duration: 0.8,
    ease: 'power2.out',
  })

  // Autoplay videos when in viewport
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const video = entry.target as HTMLVideoElement
        if (entry.isIntersecting) {
          video.play().catch(() => undefined)
        } else {
          video.pause()
        }
      })
    },
    { threshold: 0.25 },
  )

  document.querySelectorAll<HTMLVideoElement>('.branding-card .card-video').forEach((v) => {
    observer.observe(v)
  })

  // Accordion
  const allCards = Array.from(document.querySelectorAll<HTMLElement>('.branding-card'))
  const grid = document.querySelector<HTMLElement>('.branding-grid')!

  function closeAll() {
    allCards.forEach((c) => {
      const d = c.querySelector<HTMLElement>('.card-details')!
      const b = c.querySelector<HTMLButtonElement>('.card-btn')!
      gsap.to(d, { height: 0, duration: 0.4, ease: 'power2.inOut' })
      if (window.innerWidth > 640) c.style.flex = '1'
      c.style.opacity = '1'
      c.classList.remove('active')
      b.setAttribute('aria-expanded', 'false')
      d.setAttribute('aria-hidden', 'true')
    })
  }

  document.querySelectorAll<HTMLButtonElement>('.card-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card = btn.closest<HTMLElement>('.branding-card')!
      const details = card.querySelector<HTMLElement>('.card-details')!
      const isOpen = card.classList.contains('active')

      closeAll()

      if (!isOpen) {
        card.classList.add('active')
        btn.setAttribute('aria-expanded', 'true')
        details.setAttribute('aria-hidden', 'false')
        gsap.fromTo(details, { height: 0 }, { height: 'auto', duration: 0.4, ease: 'power2.inOut' })
        if (window.innerWidth > 640) {
          card.style.flex = '0.75'
          allCards.filter((c) => c !== card).forEach((c) => {
            c.style.flex = '0.3'
            c.style.opacity = '0.25'
          })
        }
      }
    })
  })
</script>
